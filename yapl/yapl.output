Grammar

    0 $accept: translation_unit $end

    1 primary_expression: IDENTIFIER
    2                   | constant
    3                   | string
    4                   | '(' expression ')'
    5                   | generic_selection

    6 constant: I_CONSTANT
    7         | F_CONSTANT
    8         | ENUMERATION_CONSTANT

    9 enumeration_constant: IDENTIFIER

   10 string: STRING_LITERAL
   11       | FUNC_NAME

   12 generic_selection: GENERIC '(' assignment_expression ',' generic_assoc_list ')'

   13 generic_assoc_list: generic_association
   14                   | generic_assoc_list ',' generic_association

   15 generic_association: type_name ':' assignment_expression
   16                    | DEFAULT ':' assignment_expression

   17 postfix_expression: primary_expression
   18                   | postfix_expression '[' expression ']'
   19                   | postfix_expression '(' argument_expression_list_opt ')'
   20                   | postfix_expression '.' IDENTIFIER
   21                   | postfix_expression PTR_OP IDENTIFIER
   22                   | postfix_expression INC_OP
   23                   | postfix_expression DEC_OP
   24                   | '(' type_name ')' '{' initializer_list '}'
   25                   | '(' type_name ')' '{' initializer_list ',' '}'

   26 argument_expression_list_opt: ε
   27                             | argument_expression_list

   28 argument_expression_list: assignment_expression
   29                         | argument_expression_list ',' assignment_expression

   30 unary_expression: postfix_expression
   31                 | INC_OP unary_expression
   32                 | DEC_OP unary_expression
   33                 | unary_operator cast_expression
   34                 | SIZEOF unary_expression
   35                 | SIZEOF '(' type_name ')'
   36                 | ALIGNOF '(' type_name ')'

   37 unary_operator: '&'
   38               | '*'
   39               | '+'
   40               | '-'
   41               | '~'
   42               | '!'

   43 cast_expression: unary_expression
   44                | '(' type_name ')' cast_expression

   45 multiplicative_expression: cast_expression
   46                          | multiplicative_expression '*' cast_expression
   47                          | multiplicative_expression '/' cast_expression
   48                          | multiplicative_expression '%' cast_expression

   49 additive_expression: multiplicative_expression
   50                    | additive_expression '+' multiplicative_expression
   51                    | additive_expression '-' multiplicative_expression

   52 shift_expression: additive_expression
   53                 | shift_expression LEFT_OP additive_expression
   54                 | shift_expression RIGHT_OP additive_expression

   55 relational_expression: shift_expression
   56                      | relational_expression '<' shift_expression
   57                      | relational_expression '>' shift_expression
   58                      | relational_expression LE_OP shift_expression
   59                      | relational_expression GE_OP shift_expression
   60                      | relational_expression TH_OP shift_expression

   61 equality_expression: relational_expression
   62                    | equality_expression EQ_OP relational_expression
   63                    | equality_expression NE_OP relational_expression

   64 and_expression: equality_expression
   65               | and_expression '&' equality_expression

   66 exclusive_or_expression: and_expression
   67                        | exclusive_or_expression '^' and_expression

   68 inclusive_or_expression: exclusive_or_expression
   69                        | inclusive_or_expression '|' exclusive_or_expression

   70 logical_and_expression: inclusive_or_expression
   71                       | logical_and_expression AND_OP inclusive_or_expression

   72 logical_or_expression: logical_and_expression
   73                      | logical_or_expression OR_OP logical_and_expression

   74 conditional_expression: logical_or_expression
   75                       | logical_or_expression '?' expression ':' conditional_expression

   76 assignment_expression: conditional_expression
   77                      | unary_expression assignment_operator assignment_expression

   78 assignment_operator: '='
   79                    | MUL_ASSIGN
   80                    | DIV_ASSIGN
   81                    | MOD_ASSIGN
   82                    | ADD_ASSIGN
   83                    | SUB_ASSIGN
   84                    | LEFT_ASSIGN
   85                    | RIGHT_ASSIGN
   86                    | AND_ASSIGN
   87                    | XOR_ASSIGN
   88                    | OR_ASSIGN
   89                    | PEQ_OP
   90                    | MEQ_OP
   91                    | STREQ_OP
   92                    | DEQ_OP
   93                    | MODEQ_OP

   94 expression: assignment_expression
   95           | expression ',' assignment_expression

   96 constant_expression: conditional_expression

   97 declaration: declaration_specifiers ';'
   98            | declaration_specifiers init_declarator_list ';'
   99            | static_assert_declaration

  100 declaration_specifiers: storage_class_specifier declaration_specifiers
  101                       | storage_class_specifier
  102                       | type_specifier declaration_specifiers
  103                       | type_specifier
  104                       | type_qualifier declaration_specifiers
  105                       | type_qualifier
  106                       | function_specifier declaration_specifiers
  107                       | function_specifier
  108                       | alignment_specifier declaration_specifiers
  109                       | alignment_specifier

  110 init_declarator_list: init_declarator
  111                     | init_declarator_list ',' init_declarator

  112 init_declarator: declarator '=' initializer
  113                | declarator

  114 storage_class_specifier: TYPEDEF
  115                        | EXTERN
  116                        | STATIC
  117                        | THREAD_LOCAL
  118                        | AUTO
  119                        | REGISTER

  120 type_specifier: VOID
  121               | CHAR
  122               | SHORT
  123               | INT
  124               | LONG
  125               | FLOAT
  126               | DOUBLE
  127               | SIGNED
  128               | UNSIGNED
  129               | BOOL
  130               | COMPLEX
  131               | IMAGINARY
  132               | atomic_type_specifier
  133               | struct_or_union_specifier
  134               | enum_specifier
  135               | TYPEDEF_NAME

  136 struct_or_union_specifier: struct_or_union '{' struct_declaration_list '}'
  137                          | struct_or_union IDENTIFIER '{' struct_declaration_list '}'
  138                          | struct_or_union IDENTIFIER

  139 struct_or_union: STRUCT
  140                | UNION

  141 struct_declaration_list: struct_declaration
  142                        | struct_declaration_list struct_declaration

  143 struct_declaration: specifier_qualifier_list ';'
  144                   | specifier_qualifier_list struct_declarator_list ';'
  145                   | static_assert_declaration

  146 specifier_qualifier_list: type_specifier specifier_qualifier_list
  147                         | type_specifier
  148                         | type_qualifier specifier_qualifier_list
  149                         | type_qualifier

  150 struct_declarator_list: struct_declarator
  151                       | struct_declarator_list ',' struct_declarator

  152 struct_declarator: ':' constant_expression
  153                  | declarator ':' constant_expression
  154                  | declarator

  155 enum_specifier: ENUM '{' enumerator_list '}'
  156               | ENUM '{' enumerator_list ',' '}'
  157               | ENUM IDENTIFIER '{' enumerator_list '}'
  158               | ENUM IDENTIFIER '{' enumerator_list ',' '}'
  159               | ENUM IDENTIFIER

  160 enumerator_list: enumerator
  161                | enumerator_list ',' enumerator

  162 enumerator: enumeration_constant '=' constant_expression
  163           | enumeration_constant

  164 atomic_type_specifier: ATOMIC '(' type_name ')'

  165 type_qualifier: CONST
  166               | RESTRICT
  167               | VOLATILE
  168               | ATOMIC

  169 function_specifier: INLINE
  170                   | NORETURN

  171 alignment_specifier: ALIGNAS '(' type_name ')'
  172                    | ALIGNAS '(' constant_expression ')'

  173 $@1: ε

  174 declarator: pointer $@1 direct_declarator
  175           | direct_declarator

  176 direct_declarator: IDENTIFIER
  177                  | '(' declarator ')'
  178                  | direct_declarator '[' ']'
  179                  | direct_declarator '[' '*' ']'
  180                  | direct_declarator '[' STATIC type_qualifier_list assignment_expression ']'
  181                  | direct_declarator '[' STATIC assignment_expression ']'
  182                  | direct_declarator '[' type_qualifier_list '*' ']'
  183                  | direct_declarator '[' type_qualifier_list STATIC assignment_expression ']'
  184                  | direct_declarator '[' type_qualifier_list assignment_expression ']'
  185                  | direct_declarator '[' type_qualifier_list ']'
  186                  | direct_declarator '[' assignment_expression ']'
  187                  | direct_declarator '(' parameter_type_list ')'
  188                  | direct_declarator '(' ')'
  189                  | direct_declarator '(' identifier_list ')'

  190 pointer: '*' type_qualifier_list pointer
  191        | '*' type_qualifier_list
  192        | '*' pointer
  193        | '*'

  194 type_qualifier_list: type_qualifier
  195                    | type_qualifier_list type_qualifier

  196 parameter_type_list: parameter_list ',' ELLIPSIS
  197                    | parameter_list

  198 parameter_list: parameter_declaration
  199               | parameter_list ',' parameter_declaration

  200 parameter_declaration: declaration_specifiers declarator
  201                      | declaration_specifiers abstract_declarator
  202                      | declaration_specifiers

  203 identifier_list: IDENTIFIER
  204                | identifier_list ',' IDENTIFIER

  205 type_name: specifier_qualifier_list abstract_declarator
  206          | specifier_qualifier_list

  207 abstract_declarator: pointer direct_abstract_declarator
  208                    | pointer
  209                    | direct_abstract_declarator

  210 direct_abstract_declarator: '(' abstract_declarator ')'
  211                           | '[' ']'
  212                           | '[' '*' ']'
  213                           | '[' STATIC type_qualifier_list assignment_expression ']'
  214                           | '[' STATIC assignment_expression ']'
  215                           | '[' type_qualifier_list STATIC assignment_expression ']'
  216                           | '[' type_qualifier_list assignment_expression ']'
  217                           | '[' type_qualifier_list ']'
  218                           | '[' assignment_expression ']'
  219                           | direct_abstract_declarator '[' ']'
  220                           | direct_abstract_declarator '[' '*' ']'
  221                           | direct_abstract_declarator '[' STATIC type_qualifier_list assignment_expression ']'
  222                           | direct_abstract_declarator '[' STATIC assignment_expression ']'
  223                           | direct_abstract_declarator '[' type_qualifier_list assignment_expression ']'
  224                           | direct_abstract_declarator '[' type_qualifier_list STATIC assignment_expression ']'
  225                           | direct_abstract_declarator '[' type_qualifier_list ']'
  226                           | direct_abstract_declarator '[' assignment_expression ']'
  227                           | '(' ')'
  228                           | '(' parameter_type_list ')'
  229                           | direct_abstract_declarator '(' ')'
  230                           | direct_abstract_declarator '(' parameter_type_list ')'

  231 initializer: '{' initializer_list '}'
  232            | '{' initializer_list ',' '}'
  233            | assignment_expression

  234 initializer_list: designation initializer
  235                 | initializer
  236                 | initializer_list ',' designation initializer
  237                 | initializer_list ',' initializer

  238 designation: designator_list '='

  239 designator_list: designator
  240                | designator_list designator

  241 designator: '[' constant_expression ']'
  242           | '.' IDENTIFIER

  243 static_assert_declaration: STATIC_ASSERT '(' constant_expression ',' STRING_LITERAL ')' ';'

  244 statement: error ';'
  245          | labeled_statement
  246          | compound_statement
  247          | expression_statement
  248          | selection_statement
  249          | iteration_statement
  250          | jump_statement

  251 labeled_statement: IDENTIFIER ':' statement
  252                  | CASE constant_expression ':' statement
  253                  | DEFAULT ':' statement

  254 compound_statement: '{' '}'
  255                   | '{' block_item_list '}'

  256 block_item_list: block_item
  257                | block_item_list block_item

  258 block_item: declaration
  259           | statement

  260 expression_statement: ';'
  261                     | expression ';'

  262 selection_statement: IF '(' expression ')' statement ELSE statement
  263                    | IF '(' expression ')' statement
  264                    | SWITCH '(' expression ')' statement

  265 iteration_statement: WHILE '(' expression ')' statement
  266                    | DO statement WHILE '(' expression ')' ';'
  267                    | FOR '(' expression_statement expression_statement ')' statement
  268                    | FOR '(' expression_statement expression_statement expression ')' statement
  269                    | FOR '(' declaration expression_statement ')' statement
  270                    | FOR '(' declaration expression_statement expression ')' statement

  271 jump_statement: GOTO IDENTIFIER ';'
  272               | CONTINUE ';'
  273               | BREAK ';'
  274               | RETURN ';'
  275               | RETURN expression ';'

  276 translation_unit: external_declaration
  277                 | translation_unit external_declaration

  278 external_declaration: function_definition
  279                     | declaration

  280 function_definition: declaration_specifiers declarator declaration_list compound_statement
  281                    | declaration_specifiers declarator compound_statement

  282 declaration_list: declaration
  283                 | declaration_list declaration


